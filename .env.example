################################################################
# CONFIGURACIÓN PARA PRODUCCIÓN EN INFINITYFREE
#
# Copia este archivo a ".env" en el servidor y rellena los datos
# de conexión MySQL que te ofreció el panel de InfinityFree.
################################################################

APP_NAME=MentActiva
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-subdominio.infinityfreeapp.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

################################################################
# BASE DE DATOS — Datos que te da el panel de InfinityFree
# (Panel > MySQL Databases > tu base de datos)
################################################################
DB_CONNECTION=mysql
DB_HOST=sqlxxx.infinityfree.com
DB_PORT=3306
DB_DATABASE=epiz_xxxxxxxx_mentactiva
DB_USERNAME=epiz_xxxxxxxx
DB_PASSWORD=tu_password_aqui

################################################################
# Sesiones, cache y queue en BD
################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
